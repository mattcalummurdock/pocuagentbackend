{
  "name": "pocu",
  "version": "2.0.0",
  "description": "On-Chain CPU — Hedera tensor compute engine (cpuarc)",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.ts --network testnet",
    "deploy:hts": "hardhat run scripts/deploy-hts-model-collection.ts --network testnet",
    "train": "hardhat run scripts/train.ts --network testnet",
    "test-model": "hardhat run scripts/test-model.ts --network testnet",
    "generate-data": "hardhat run scripts/generate-data.ts",
    "preprocess-tabular": "hardhat run scripts/preprocess-tabular.ts",
    "export-architectures": "ts-node scripts/export-architectures.ts",
    "send-hbar": "ts-node scripts/send-hbar.ts",
    "jobs:worker": "ts-node src/jobs/worker.ts",
    "jobs:worker:once": "ts-node src/jobs/worker.ts --once",
    "dev:web": "cd web && npm run dev",
    "dev:agent": "python -m uvicorn main:app --reload --host 127.0.0.1 --port 8000 --app-dir agent",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:agent\" \"npm run jobs:worker\""
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "chai": "^4.5.0",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@hashgraph/sdk": "^2.81.0",
    "@supabase/supabase-js": "^2.49.0",
    "concurrently": "^9.1.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "onnx-proto": "^8.0.1",
    "onnxruntime-node": "^1.20.1",
    "protobufjs": "^7.4.0",
    "ws": "^8.21.0"
  }
} 
